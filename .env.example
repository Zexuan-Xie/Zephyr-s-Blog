# xLab Blog local development defaults.
# Copy to .env and replace all secrets before starting Docker Compose or the API.

# Postgres / pgvector
POSTGRES_DB=xlab_blog
POSTGRES_USER=xlab_blog
POSTGRES_PASSWORD=change-me-postgres-password
DATABASE_URL=postgres://xlab_blog:change-me-postgres-password@db:5432/xlab_blog?sslmode=disable

# API
API_HOST=0.0.0.0
API_PORT=8080
JWT_SECRET=change-me-minimum-32-bytes
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password
ASSET_UPLOAD_DIR=/app/uploads
ASSET_PUBLIC_BASE_URL=/api/assets

# Frontend / edge
PUBLIC_SITE_URL=http://localhost:8080
VITE_API_BASE_URL=/api

# Qwen / DashScope embeddings
EMBEDDING_PROVIDER=qwen
DASHSCOPE_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
