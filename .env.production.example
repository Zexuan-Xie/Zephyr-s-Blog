# Aeolian Blog production environment template.
# Copy to .env on the server and replace every CHANGE_ME value before `docker compose up`.
# Do not commit the real .env file.

# Public edge
# No domain yet: keep 8080 and visit http://154.37.222.233:8080
# With a domain/HTTPS later: use 80/443 and update Caddyfile separately.
PUBLIC_HTTP_PORT=8080
PUBLIC_SITE_URL=http://154.37.222.233:8080
VITE_API_BASE_URL=/api

# PostgreSQL / pgvector
POSTGRES_DB=xlab_blog
POSTGRES_USER=xlab_blog
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_32
DATABASE_URL=postgres://xlab_blog:CHANGE_ME_SAME_AS_POSTGRES_PASSWORD@db:5432/xlab_blog?sslmode=disable

# API
HTTP_ADDR=:8080
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_48
ADMIN_EMAIL=CHANGE_ME_AUTHOR_EMAIL@example.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_AUTHOR_PASSWORD
ASSET_UPLOAD_DIR=/app/uploads
ASSET_PUBLIC_BASE_URL=/api/assets

# Search embeddings.
# Leave DASHSCOPE_API_KEY empty to keep lexical/full-text fallback only.
EMBEDDING_PROVIDER=qwen
DASHSCOPE_API_KEY=
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
